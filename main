-- MAIN GUI SCRIPT (LocalScript, place in StarterPlayerScripts)

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Grab the global config
local Config = _G.AgilityConfig or {
    DefaultMoveValue = -6,
    DefaultSetSpeedValue = 16,
    DefaultSetJumpValue = 50,
    EmergencyJumpValue = 1.5,
    EmergencySpeedValue = nil,
    DeadlyEmergencySpeedValue = 30,
    DeadlyEmergencyJumpValue = 2
}

-- GUI Parenting persistent
local screenGui = player:WaitForChild("PlayerGui"):FindFirstChild("AgilityUtilGui")
if not screenGui then
    screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AgilityUtilGui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = player:WaitForChild("PlayerGui")
end

-- VARIABLES
local homeCFrames = {nil, nil, nil}
local emergencyActive = false
local deadlyActive = false
local originalSpeed = Config.DefaultSetSpeedValue
local originalJump = Config.DefaultSetJumpValue

-- FUNCTIONS
local function getHumanoid()
    local char = player.Character
    if char then
        return char:FindFirstChild("Humanoid"), char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function createButton(text, position, parent, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 120, 0, 45)
    btn.Position = position
    btn.Text = text
    btn.BackgroundColor3 = color or Color3.fromRGB(0, 170, 255)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextScaled = true
    btn.AutoButtonColor = true
    btn.Parent = parent
    btn.TextStrokeTransparency = 0.7

    -- UICorner
    local uic = Instance.new("UICorner")
    uic.CornerRadius = UDim.new(0, 8)
    uic.Parent = btn

    -- UIStroke
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(0,0,0)
    stroke.Thickness = 1
    stroke.Parent = btn

    return btn
end

local function createTextbox(position, parent, default)
    local tb = Instance.new("TextBox")
    tb.Size = UDim2.new(0, 80, 0, 45)
    tb.Position = position
    tb.Text = tostring(default)
    tb.PlaceholderText = tostring(default)
    tb.BackgroundColor3 = Color3.fromRGB(255,255,255)
    tb.TextColor3 = Color3.fromRGB(0,0,0)
    tb.Font = Enum.Font.Gotham
    tb.TextScaled = true
    tb.ClearTextOnFocus = false
    tb.TextStrokeTransparency = 0.8
    tb.Parent = parent

    local uic = Instance.new("UICorner")
    uic.CornerRadius = UDim.new(0, 6)
    uic.Parent = tb

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(0,0,0)
    stroke.Thickness = 1
    stroke.Parent = tb

    return tb
end

-- FRAME
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 260, 0, 500)
frame.Position = UDim2.new(0, 20, 0.1, 0)
frame.BackgroundTransparency = 0.6
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.Parent = screenGui

-- UICorner and Stroke
local frameCorner = Instance.new("UICorner")
frameCorner.CornerRadius = UDim.new(0, 12)
frameCorner.Parent = frame

local frameStroke = Instance.new("UIStroke")
frameStroke.Color = Color3.fromRGB(0,0,0)
frameStroke.Thickness = 2
frameStroke.Parent = frame

-- TITLE
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,50)
title.Position = UDim2.new(0,0,0,0)
title.Text = "samurainumber1's Agility Utilities"
title.Font = Enum.Font.GothamBold
title.TextScaled = true
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.BackgroundTransparency = 1
title.Parent = frame

-- MOVE
local moveBox = createTextbox(UDim2.new(0, 130, 0, 60), frame, Config.DefaultMoveValue)
local moveButton = createButton("Move", UDim2.new(0, 10, 0, 60), frame)
moveButton.MouseButton1Click:Connect(function()
    local humanoid, hrp = getHumanoid()
    if hrp then
        local studs = tonumber(moveBox.Text)
        if studs then
            hrp.CFrame = hrp.CFrame + Vector3.new(0, studs, 0)
        end
    end
end)

-- HOMES
for i=1,3 do
    local setBtn = createButton("Set Home "..i, UDim2.new(0,10,0,100+ (i-1)*60), frame)
    setBtn.MouseButton1Click:Connect(function()
        local humanoid, hrp = getHumanoid()
        if hrp then
            homeCFrames[i] = hrp.CFrame
        end
    end)
    local goBtn = createButton("Home "..i, UDim2.new(0,140,0,100+ (i-1)*60), frame)
    goBtn.MouseButton1Click:Connect(function()
        local humanoid, hrp = getHumanoid()
        if hrp and homeCFrames[i] then
            hrp.CFrame = homeCFrames[i]
        end
    end)
end

-- SPEED & JUMP
local speedBox = createTextbox(UDim2.new(0,130,0,280), frame, Config.DefaultSetSpeedValue)
local speedButton = createButton("Set Speed", UDim2.new(0,10,0,280), frame)
speedButton.MouseButton1Click:Connect(function()
    local humanoid = getHumanoid()
    if humanoid then
        local s = tonumber(speedBox.Text)
        if s then
            humanoid.WalkSpeed = s
            originalSpeed = s
        end
    end
end)

local jumpBox = createTextbox(UDim2.new(0,130,0,340), frame, Config.DefaultSetJumpValue)
local jumpButton = createButton("Set Jump", UDim2.new(0,10,0,340), frame)
jumpButton.MouseButton1Click:Connect(function()
    local humanoid = getHumanoid()
    if humanoid then
        local j = tonumber(jumpBox.Text)
        if j then
            humanoid.JumpPower = j
            originalJump = j
        end
    end
end)

-- EMERGENCY
local emergencyButton = createButton("Emergency (Y)", UDim2.new(0,10,0,400), frame, Color3.fromRGB(255,0,0))
local function toggleEmergency()
    local humanoid = getHumanoid()
    if humanoid then
        if emergencyActive then
            humanoid.JumpPower = originalJump
            emergencyActive = false
        else
            humanoid.JumpPower = originalJump * Config.EmergencyJumpValue
            emergencyActive = true
        end
    end
end
emergencyButton.MouseButton1Click:Connect(toggleEmergency)

-- DEADLY EMERGENCY
local deadlyButton = createButton("Deadly Emergency (E)", UDim2.new(0,10,0,460), frame, Color3.fromRGB(150,0,0))
local function toggleDeadly()
    local humanoid = getHumanoid()
    if humanoid then
        if deadlyActive then
            humanoid.WalkSpeed = originalSpeed
            humanoid.JumpPower = emergencyActive and originalJump*Config.EmergencyJumpValue or originalJump
            deadlyActive = false
        else
            humanoid.WalkSpeed = Config.DeadlyEmergencySpeedValue
            humanoid.JumpPower = humanoid.JumpPower * Config.DeadlyEmergencyJumpValue
            deadlyActive = true
        end
    end
end
deadlyButton.MouseButton1Click:Connect(toggleDeadly)

-- KEYBINDS
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Y then
        toggleEmergency()
    elseif input.KeyCode == Enum.KeyCode.E then
        toggleDeadly()
    end
end)
